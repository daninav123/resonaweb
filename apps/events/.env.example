# Google Ads — conversion tracking (resonaevents.com)
# El ID y los labels salen de Google Ads → Objetivos → Conversiones (tag de cada acción).
# Sin estas variables, las conversiones de GA4 (purchase/lead) siguen funcionando,
# pero NO se envían a Google Ads.
# PURCHASE_LABEL = señal pagada (reserva-confirmada) · LEAD_LABEL = brief/contacto.
VITE_GOOGLE_ADS_ID="AW-XXXXXXXXXX"
VITE_GOOGLE_ADS_PURCHASE_LABEL=""
VITE_GOOGLE_ADS_LEAD_LABEL=""

# Meta Pixel — Facebook/Instagram Ads (resonaevents.com)
# ID numérico del pixel desde Meta Events Manager. Solo se carga si el usuario
# acepta cookies de marketing. Vacío = desactivado.
VITE_META_PIXEL_ID=""
